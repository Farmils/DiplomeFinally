{
  "name": "diplomev2front",
  "private": true,
  "version": "1.0.0",
  "description": "NFT Marketplace Desktop App",
  "author": "Your Name",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:build:linux": "vite build && electron-builder --linux",
    "electron:build:win": "vite build && electron-builder --windows --x64",
    "electron:build:all": "vite build && electron-builder --linux --windows",
    "docker:build:win": "bash build-windows-docker.sh"
  },
  "dependencies": {
    "@pinata/sdk": "^2.1.0",
    "@tanstack/react-query": "^5.62.0",
    "axios": "^1.7.0",
    "bootstrap": "^5.3.3",
    "react": "^18.3.1",
    "react-bootstrap": "^2.10.7",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "viem": "^2.21.0",
    "wagmi": "^2.12.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "gh-pages": "^6.0.0",
    "vite": "^5.4.11"
  },

  "build": {
    "appId": "com.nftmarketplace.app",
    "productName": "NFT Marketplace",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "npmRebuild": false,
    "nodeGypRebuild": false,
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "public/icon.png"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  }
}
